# Telegram Bot Token (BotFather'dan olinadi)
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL Database
DATABASE_URL=postgresql://carbor:carbor_secret@localhost:5432/carbor_db

# Redis (Scraper <-> Bot aloqasi uchun)
REDIS_URL=redis://localhost:6379

# Bot Settings
BOT_ADMIN_ID=your_telegram_id_here
